                "template",
                "spoiler"
            ],
            "default": true,
            "group": "Vehicle Options"
        },
        "include_premium":{
            "display_name": "Include Premium Vehicles",
            "description": [
                "Some BRs on certain Nations are only available via Premium Vehicles.",
                "Activating this adds them to logic.",
                "Mostly relevant for Helicopters or when using Complex Vehicle Types option."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Vehicle Options"
        },
        "include_old_vehicles":{
            "display_name": "Include Old Vehicles",
            "description": [
                "Adapts logic to make use of old Vehicles. Only for long-time Collectors!",
                "Old Vehicles are no longer (or not currently) available for purchase (Mostly Premium!).",
                "Mostly relevant for the Complex Vehicle Types option."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Vehicle Options"
        },
        "exclude_usa":{
            "display_name": "Exclude USA",
