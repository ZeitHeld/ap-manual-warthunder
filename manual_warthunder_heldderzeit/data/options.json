{
    "$schema": "https://raw.githubusercontent.com/ManualForArchipelago/Manual/main/schemas/Manual.options.schema.json",
    "_comment": "Add a _ before an option name to comment it out and it wont be added to the apworld",
    "core": {
        "goal":{
            "_comment": [
                "Using 'goal' as the name of an option let you override some of the generated goal parameters"
            ],
            "display_name": "The End Objective",
            "description": "How to End your Randomized playthrough.",
            "aliases": {"easiest": 0},
            "hidden": false
        },
        "death_link": {
            "default": false
        },
        "filler_traps": {
            "_comment": "Using values here let you set a 'recommended' filler_trap percentage or even a default percentage",
            "values": {
                "recommended": 20
            }
        }
    },
    "user": {
        "_commented_out_option":{
            "type": "Toggle",
            "default": true
        },
        "_Example_Toggle":{
            "description": [
                "This is a Toggle",
                "A simple boolean, aka True or False set the initial value with \"default\""
            ],
            "type": "Toggle",
            "default": false,
            "group": "Example Options"
        },

        "_Example_Choice":{
            "type": "Choice",
            "description": [
                "This is a Choice",
                "Let the user pick from a list of values",
                "allow_custom_value let a player define their own text value",
                "Currently the only use for Choice in Manual outside of hooks is the goal"
            ],
            "values": {
                "start":0,
                "test":1
             },
            "default": 0,
            "allow_custom_value": false,
            "group": "Example Options"
        },
        "_Example_Range":{
            "type": "Range",
            "description": [
                "This is a Range",
                "Allow the player to specify a value between 'start' and 'end'",
                "if you include a \"values\" you can define the label for certain values",
                "Currently the only use for Range in Manual outside of hooks is 'filler_trap'"
            ],
            "range_start": 0,
            "default": 1,
            "range_end": 5,
            "values": {"example": 2},
            "group": "Example Options"
        },
        "goal":{
            "display_name": "Goal",
            "type": "Choice",
            "description": [
                "The Goal",
                "'Get a Nuke' - Tanks only",
                "'Wins' - uses 'Required Wins' as Amount",
                "'Kills' - uses 'Required Kills'"
            ],
            "values": {
                "nuke":0,
                "wins":1,
                "kills":2
             },
            "default": 1,
            "allow_custom_value": false,
            "group": "Goal Options"
        },
        "goal_per_nation":{
            "display_name": "Goal per Nation",
            "description": [
                "Uses 'Required Nations' and applies it onto the goal.",
                "requiring the Goal to be achieved for each nation."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Goal Options"
        },
        "required_nations":{
            "display_name": "Required Nations",
            "type": "Range",
            "description": [
                "This is a Range",
                "Allow the player to specify a value between 'start' and 'end'",
                "if you include a \"values\" you can define the label for certain values",
                "Currently the only use for Range in Manual outside of hooks is 'filler_trap'"
            ],
            "range_start": 1,
            "default": 5,
            "range_end": 10,
            "values": {
                "default": 5,
                "one": 1,
                "all": 10
            },
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "group": "Goal Options"
        },
        "required_wins":{
            "display_name": "Required Wins",
            "type": "Range",
            "description": [
                "This is a Range",
                "Allow the player to specify a value between 'start' and 'end'",
                "if you include a \"values\" you can define the label for certain values",
                "Currently the only use for Range in Manual outside of hooks is 'filler_trap'"
            ],
            "range_start": 5,
            "default": 10,
            "range_end": 50,
            "values": {
                "old_default": 20,
                "least": 5,
                "max": 50,
                "half": 25
            },
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "group": "Goal Options"
        },
        "required_kills":{
            "display_name": "Required Kills",
            "type": "Range",
            "description": [
                "This is a Range",
                "Allow the player to specify a value between 'start' and 'end'",
                "if you include a \"values\" you can define the label for certain values",
                "Currently the only use for Range in Manual outside of hooks is 'filler_trap'"
            ],
            "range_start": 10,
            "default": 30,
            "range_end": 100,
            "values": {
                "default": 30,
                "least": 10,
                "most": 100,
                "half": 50
            },
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "group": "Goal Options"
        },
        "progressive_br":{
            "display_name": "Progressive BR",
            "description": "Should the found BRs be progressive?",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true,
            "group": "General Options"
        },
        "exclude_tanks":{
            "display_name": "Exclude Ground Vehicles",
            "description": "Turn on, if you don't want to play Ground Vehicles.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "exclude_planes":{
            "display_name": "Exclude Aviation",
            "description": "Turn on, if you don't want to play Exclude Aviation.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "exclude_helis":{
            "display_name": "Exclude Helicopter",
            "description": "Turn on, if you don't want to play Exclude Helicopter.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "exclude_bluefleet":{
            "display_name": "Exclude Bluewater Fleet",
            "description": "Turn on, if you don't want to play Bluewater Fleet.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "exclude_coastals":{
            "display_name": "Exclude Coastal Fleet",
            "description": "Turn on, if you don't want to play Coastal Fleet.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "include_premium":{
            "display_name": "Include Premium Vehicles",
            "description": "Should Premium Vehicles be included into logic?",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        }
    }

}
