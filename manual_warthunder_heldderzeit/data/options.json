        },
        "ejection_traps":{
            "display_name": "Ejection Traps",
            "description": "When receiving an \"Ejection Trap\", you must eject yourself from the current vehicle immediately.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true,
