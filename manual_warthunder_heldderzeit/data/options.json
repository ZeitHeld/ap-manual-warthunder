{
    "$schema": "https://raw.githubusercontent.com/ManualForArchipelago/Manual/main/schemas/Manual.options.schema.json",
    "_comment": "Add a _ before an option name to comment it out and it wont be added to the apworld",
    "core": {
        "goal":{
            "_comment": [
                "Using 'goal' as the name of an option let you override some of the generated goal parameters"
            ],
            "display_name": "The End Objective",
            "description": "How to End your Randomized playthrough.",
            "aliases": {"easiest": 0},
            "hidden": false
        },
        "death_link": {
            "default": false
        },
        "filler_traps": {
            "_comment": "Using values here let you set a 'recommended' filler_trap percentage or even a default percentage",
            "values": {
                "recommended": 20
            }
        }
    },
    "user": {
        "goal":{
            "display_name": "Goal",
            "_type": "Choice",
            "_description": [
                "The Goal",
                "'Get a Nuke' - Tanks only",
                "'Wins' - uses 'Required Wins' as Amount",
                "'Kills' - uses 'Required Kills'"
            ],
            "_values": {
                "nuke":0,
                "wins":1,
                "kills":2
             },
            "_default": 1,
            "allow_custom_value": false,
            "group": "Goal Options"
        },
        "_goal_per_nation":{
            "display_name": "Goal per Nation",
            "description": [
                "Uses 'Required Nations' and applies it onto the goal.",
                "requiring the Goal to be achieved for each nation."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Goal Options"
        },
        "_required_nations":{
            "display_name": "Required Nations",
            "type": "Range",
            "description": [
                "This is a Range",
                "Allow the player to specify a value between 'start' and 'end'",
                "if you include a \"values\" you can define the label for certain values",
                "Currently the only use for Range in Manual outside of hooks is 'filler_trap'"
            ],
            "range_start": 1,
            "default": 5,
            "range_end": 10,
            "values": {
                "default": 5,
                "one": 1,
                "all": 10
            },
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "group": "Goal Options"
        },
        "_required_wins":{
            "display_name": "Required Wins",
            "type": "Range",
            "description": [
                "This is a Range",
                "Allow the player to specify a value between 'start' and 'end'",
                "if you include a \"values\" you can define the label for certain values",
                "Currently the only use for Range in Manual outside of hooks is 'filler_trap'"
            ],
            "range_start": 5,
            "default": 10,
            "range_end": 50,
            "values": {
                "old_default": 20,
                "least": 5,
                "max": 50,
                "half": 25
            },
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "group": "Goal Options"
        },
        "_required_kills":{
            "display_name": "Required Kills",
            "type": "Range",
            "description": [
                "This is a Range",
                "Allow the player to specify a value between 'start' and 'end'",
                "if you include a \"values\" you can define the label for certain values",
                "Currently the only use for Range in Manual outside of hooks is 'filler_trap'"
            ],
            "range_start": 10,
            "default": 30,
            "range_end": 100,
            "values": {
                "default": 30,
                "least": 10,
                "most": 100,
                "half": 50
            },
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "group": "Goal Options"
        },
        "progressive_br":{
            "display_name": "Progressive BR",
            "description": [
                "Should the found BRs be progressive (in order)",
                "or mixed and found separately?"
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true,
            "group": "General Options"
        },
        "upgrade_shuffle":{
            "display_name": "Shuffle Upgrades",
            "description": [
                "WIP - Aviation only",
                "Whether or not Modifications and Ammos need to be found to be used.",
                "If turned on, disable all Modifications and you're not allowed to use",
                "any Ammo other than the defaults in the top row, until it has been found."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "include_base_abilities":{
            "display_name": "Shuffle Base Abilities",
            "description": [
                "WIP - Aviation only",
                "Does nothing if \"Shuffle Upgrades\" is disabled.",
                "If turned on, also shuffle around base abilities, like repairing, flaps."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "include_advanced_abilities":{
            "display_name": "Shuffle Advanced Abilities",
            "description": [
                "WIP - Aviation only",
                "Does nothing if \"Shuffle Upgrades\" is disabled.",
                "If turned on, also shuffle around advanced abilities for vehicles with a high BR, like radar, thrust vectoring."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "extra_missions":{
            "display_name": "Extra Mission",
            "description": [
                "Adds in Extra Missions as checks.",
                "Some can be as simple as \"Make 5 Kills\", or as specific as.",
                "If turned on, disable all Modifications and you're not allowed to use",
                "any Ammo other than the defaults in the top row, until it has been found."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "General Options"
        },
        "complex_vehicles":{
            "display_name": "Complex Vehicle Types (Game Roles)",
            "description": [
                "Splits up the regular Vehicle types into their more \"complex\" Game Roles.",
                "Example: Aviation -> Fighter/Bomber/Strike Aircraft"
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Vehicle Options"
        },
        "exclude_planes":{
            "display_name": "Exclude Aviation",
            "description": "Turn on, if you don't want to play Exclude Aviation with any Nation.",
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": false,
            "group": "Vehicle Options"
        },
        "exclude_helis":{
            "display_name": "Exclude Helicopter",
            "description": [
                "Turn on, if you don't want to play Exclude Helicopter with any Nation."
            ],
            "type": "Toggle",
            "visibility": [
                "simple_ui",
                "complex_ui",
                "template",
                "spoiler"
            ],
            "default": true,
            "group": "Vehicle Options"
        },
        "exclude_tanks":{
            "display_name": "Exclude Ground Vehicles",
            "description": [
